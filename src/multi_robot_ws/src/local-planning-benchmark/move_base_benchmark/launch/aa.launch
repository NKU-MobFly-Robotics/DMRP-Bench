<launch>

  <!--  ************** Global Parameters ***************  -->
  <param name="/use_sim_time" value="true" />
  <arg name="gui" default="true" />
  <arg name="scene" default="freeOffice" />

  <!-- Initial pose -->
  <arg name="initial_pose_x" default="8.671" />
  <arg name="initial_pose_y" default="-12.264" />
  <arg name="initial_pose_a" default="1.571" />

  <!-- Filename -->
  <arg name="log_filename" default="$(find move_base_benchmark)/launch/log.txt" />
  <!-- <arg name="map_filename" default="$(find move_base_benchmark)/maps/$(arg scene)/Library_low_reso.yaml" /> -->
  <!-- <arg name="map_filename" default="$(find move_base_benchmark)/maps/$(arg scene)/$(arg scene)_low_reso.yaml" /> -->
  <arg name="map_filename" default="$(find move_base_benchmark)/maps/$(arg scene)/map.yaml" />
  <arg name="global_frame" value="map" />

  <!--  ****** Maps *****  -->
  <node name="map_server" pkg="map_server" type="map_server" args="$(arg map_filename)" output="screen">
    <param name="frame_id" value="$(arg global_frame)" />
    <!-- change resolution to 0.1 -->
    <param name="resolution" value="0.5" />
  </node>


  <!--  ******launch robot model *****  -->
  <node pkg="move_base_benchmark" type="tf_publish.py" name="tf_publish" output="screen"/>
  
  <group if="$(eval arg('scene') == 'freeOffice')">
    <group ns="p1">
      <include file="$(find p3dx_gazebo)/launch/spawn_p3dx.launch">
      </include> 
    </group>
    
    <group ns="p2">
      <include file="$(find p3dx_gazebo)/launch/spawn_p3dx.launch">
      </include> 
    </group>
    
    <group ns="p3">
      <include file="$(find p3dx_gazebo)/launch/spawn_p3dx.launch">
      </include> 
    </group>
    
    <group ns="p4">
      <include file="$(find p3dx_gazebo)/launch/spawn_p3dx.launch">
      </include> 
    </group>
  </group>

  <group if="$(eval arg('scene') == 'Library')">
    <group ns="p1">
      <include file="$(find p3dx_gazebo)/launch/spawn_p3dx.launch">
      </include> 
    </group>
    
    <group ns="p2">
      <include file="$(find p3dx_gazebo)/launch/spawn_p3dx.launch">
      </include> 
    </group>
    
    <group ns="p3">
      <include file="$(find p3dx_gazebo)/launch/spawn_p3dx.launch">
      </include> 
    </group>
    
    <group ns="p4">
      <include file="$(find p3dx_gazebo)/launch/spawn_p3dx.launch">
      </include> 
    </group>
  </group>

  <group if="$(eval arg('scene') == 'Shopping')">
    <group ns="p1">
      <include file="$(find p3dx_gazebo)/launch/spawn_p3dx.launch">
      </include> 
    </group>
    
    <group ns="p2">
      <include file="$(find p3dx_gazebo)/launch/spawn_p3dx.launch">
      </include> 
    </group>
    
    <group ns="p3">
      <include file="$(find p3dx_gazebo)/launch/spawn_p3dx.launch">
      </include> 
    </group>
    
    <group ns="p4">
      <include file="$(find p3dx_gazebo)/launch/spawn_p3dx.launch">
      </include> 
    </group>
  </group>

  <group if="$(eval arg('scene') == 'Test')">
    <group ns="p1">
      <include file="$(find p3dx_gazebo)/launch/1.launch">
      </include> 
    </group>
    
    <group ns="p2">
      <include file="$(find p3dx_gazebo)/launch/2.launch">
      </include> 
    </group>
    
    <group ns="p3">
      <include file="$(find p3dx_gazebo)/launch/3.launch">
      </include> 
    </group>
    
    <group ns="p4">
      <include file="$(find p3dx_gazebo)/launch/4.launch">
      </include> 
    </group>

    <group ns="p5">
      <include file="$(find p3dx_gazebo)/launch/5.launch">
      </include> 
    </group>

    <group ns="p6">
      <include file="$(find p3dx_gazebo)/launch/6.launch">
      </include> 
    </group>
  </group>

  <include file="$(find move_base_benchmark)/launch/move_base_single.launch">
    <arg name="robot_namespace" value="p1" />
  </include>

  <include file="$(find move_base_benchmark)/launch/move_base_single.launch">
    <arg name="robot_namespace" value="p2" />
  </include>

  <include file="$(find move_base_benchmark)/launch/move_base_single.launch">
    <arg name="robot_namespace" value="p3" />
  </include>

  <include file="$(find move_base_benchmark)/launch/move_base_single.launch">
    <arg name="robot_namespace" value="p4" />
  </include>

  <include file="$(find move_base_benchmark)/launch/move_base_single.launch">
    <arg name="robot_namespace" value="p5" />
  </include>

  <include file="$(find move_base_benchmark)/launch/move_base_single.launch">
    <arg name="robot_namespace" value="p6" />
  </include>

  <!--  **************** Visualisation ****************  -->
  <node name="rviz" pkg="rviz" type="rviz" args="-d $(find move_base_benchmark)/launch/rviz_navigation_6.rviz" />

</launch>
